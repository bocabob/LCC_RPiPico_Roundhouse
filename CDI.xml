<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="http://openlcb.org/trunk/prototypes/xml/xslt/cdi.xsl"?>
<cdi xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://openlcb.org/schema/cdi/1/4/cdi.xsd">
    <identification>
        <manufacturer>Gamble</manufacturer>
        <model>Roundhouse Controller</model>
        <hardwareVersion>3.0</hardwareVersion>
        <softwareVersion>14.1</softwareVersion>
    </identification>
    <acdi/>
    <segment origin="0" space="253">
        <name>Node</name>
        <group>
            <name>Node ID</name>
            <description>User-provided description of the node</description>
            <string size="63">
                <name>Node Name</name>
            </string>
            <string size="64">
                <name>Node Description</name>
            </string>
        </group>
    </segment>
    <segment origin="127" space="253">
        <name>Reset Control</name>
        <description>Controls Actions at Next Board Reset. Reloading User or Factory Defaults</description>
        <int size="1">
            <name>Flag</name>
            <default>238</default>
            <map>
                <relation>
                    <property>238</property>
                    <value>Normal Operation</value>
                </relation>
                <relation>
                    <property>51</property>
                    <value>Clear Everything but Create New Unused EventIDs</value>
                </relation>
                <relation>
                    <property>255</property>
                    <value>Clear Everything back to Factory Defaults</value>
                </relation>
            </map>
        </int>
    </segment>
    <segment origin="128" space="253">
        <description>Setup for Roundhouse control.</description>  
        <int size='1'>
            <name>Active Doors</name><description>Number of active doors</description>
            <min>0</min><max>16</max><default>10</default>
        </int>
        <int size='1'>
        <name>Door Speed</name>
            <description>Angular Velocity</description>
            <min>10</min><max>255</max><default>20</default>
            <hints><slider tickSpacing='60' immediate='no' showValue='yes'></slider></hints>
        </int>
        <eventid><name>Open All Doors (C)</name></eventid>
        <eventid><name>Close All Doors (C)</name></eventid>
        <group replication='16'> 
            <name>Bay</name>
            <repname>D:1</repname>
            <string size='16'><name>Description</name></string>
            <string size='5'><name>Short Name</name></string>   
            <eventid><name>Door Open (C+P)</name><description>Consumed: command to open. Produced: confirmed open. (PAIRED-EVENT EXPERIMENT v2)</description></eventid>
            <eventid><name>Door Close (C+P)</name><description>Consumed: command to close. Produced: confirmed closed. (PAIRED-EVENT EXPERIMENT v2)</description></eventid>
            <int size="1">
                <name>Servo Minimum Angle</name>
                <description>Angular Position</description>
                <min>0</min><max>180</max>
                <default>45</default>  <!-- displayed as -45°; stored as 45 -->
                <hints><slider tickSpacing="45" immediate="yes" showValue="yes"/></hints>
            </int>
            <int size="1">
                <name>Servo Maximum Angle</name>
                <description>Angular Position</description>
                <min>0</min><max>180</max>
                <default>160</default>  <!-- displayed as 70°; stored as 160 -->
                <hints><slider tickSpacing="45" immediate="yes" showValue="yes"/></hints>
            </int>
        </group>        
        <group>
            <name>Lights</name>
            <description>Parameters for Light control</description>
            <eventid><name>Toggle Interior Lights (C)</name></eventid>
            <eventid><name>Toggle Exterior Lights (C)</name></eventid>
            <int size='1'>
            <name>Maximum Luminosity</name>
                <description>Full luminesence factor</description>
                <min>10</min><max>255</max><default>150</default>
            <hints><slider tickSpacing='60' immediate='no' showValue='yes'></slider></hints>
            </int>
            <eventid><name>Full Luminosity On</name></eventid>
            <int size='1'>
            <name>Minimum Luminosity</name>
                <description>Dimmed luminesence factor</description>
                <min>10</min><max>255</max><default>50</default>
            <hints><slider tickSpacing='60' immediate='no' showValue='yes'></slider></hints>
            </int>
            <eventid><name>Low Luminosity On</name></eventid>
        </group>
    </segment>
</cdi>
